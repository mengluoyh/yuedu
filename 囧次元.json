[
    {
        "articleStyle": 2,
        "customOrder": 1,
        "enableJs": true,
        "enabled": true,
        "enabledCookieJar": true,
        "header": "{\n  \"User-Agent\": \"Mozilla/5.0 (Linux; Android 14; 23113RKC6C Build/UKQ1.230804.001) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/142.0.6261.119 Mobile Safari/537.36\",\n  \"\n  }",
        "lastUpdateTime": 0,
        "loadWithBaseUrl": true,
        "loginUrl": "https://jciyuan.com/user/login.html",
        "ruleArticles": ".module-item",
        "ruleContent": "<js>\n(function() {\n    var doc = org.jsoup.Jsoup.parse(result);\n    var tabs = doc.select('.module-tab-item span');\n    var lists = doc.select('.module-play-list-content');\n\n    if (lists.size() == 0) { \n        return \"未找到剧集线路，可能是网络拦截或页面结构已改变。\"; \n    }\n\n    function esc(s) { return String(s||\"\").replace(/&/g,\"&amp;\").replace(/</g,\"&lt;\").replace(/>/g,\"&gt;\"); }\n    var titleNode = doc.select(\"title\");\n    var titleText = titleNode.size() > 0 ? titleNode.text().split('-')[0].trim() : \"未知视频\";\n\n    var html = \"\";\n    html += \"<style>\";\n    html += \"*{box-sizing:border-box;}\";\n    html += \"body{background:#111;margin:0;padding:12px;font-family:sans-serif;}\";\n    \n    /* 标语样式 */\n    html += \".v-warn{color:#ff4d4f;font-size:12px;background:#251818;padding:8px;border-radius:6px;margin-bottom:12px;text-align:center;border:1px solid #4a1f1f;line-height:1.4;}\";\n    \n    html += \".top-title{font-size:18px;font-weight:bold;text-align:center;color:#eee;margin-bottom:12px;line-height:1.4;word-wrap:break-word;}\";\n    \n    /* 播放器区域 */\n    html += \"#playerBox{width:100%;aspect-ratio:16/9;border-radius:8px;overflow:hidden;background:#000;position:relative;}\";\n    html += \"#playerBox iframe, #playerBox video{width:100%;height:100%;border:none;outline:none;}\";\n    html += \".msg{color:#ccc;text-align:center;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:14px;width:90%;line-height:1.6;}\";\n    \n    /* 上下集控制区 */\n    html += \".player-ctrl{display:flex;justify-content:space-between;margin:10px 0 16px 0;gap:10px;}\";\n    html += \".ctrl-btn{flex:1;border:none;padding:10px;border-radius:6px;background:#222;color:#aaa;font-size:13px;cursor:pointer;font-weight:bold;transition:background 0.2s;}\";\n    html += \".ctrl-btn:active{background:#333;color:#fff;}\";\n    \n    /* 历史记录提示 */\n    html += \".history-tip{font-size:13px;color:#bbb;margin-bottom:12px;padding:6px 10px;background:#1c283d;border-radius:6px;display:block;border:1px solid #2b3e5c;line-height:1.4;}\";\n    \n    /* 工具栏 (线路 + 正倒序布局) */\n    html += \".toolbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;gap:10px;}\";\n    html += \".line-tabs{display:flex;gap:8px;overflow-x:auto;flex:1;}\";\n    html += \".line-tabs::-webkit-scrollbar{display:none;}\";\n    html += \".tab-btn{flex:0 0 auto;border:none;padding:6px 12px;border-radius:6px;background:#333;color:#ccc;font-size:13px;cursor:pointer;}\";\n    html += \".tab-btn.active{background:#4f8cff;color:#fff;font-weight:bold;}\";\n    html += \".sort-btn{border:none;padding:6px 12px;border-radius:6px;background:#444;color:#eee;font-size:13px;cursor:pointer;white-space:nowrap;}\";\n    \n    /* 剧集列表 */\n    html += \".ep-list{display:none;flex-wrap:wrap;gap:8px;}\";\n    html += \".ep-btn{width:calc(25% - 6px);border:none;padding:8px 4px;border-radius:6px;background:#222;color:#ccc;font-size:13px;cursor:pointer;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}\";\n    html += \".ep-btn.active{background:#ff9800;color:#fff;font-weight:bold;}\";\n    html += \"</style>\";\n\n    /* 置顶注入警告标语 */\n    html += \"<div class='v-warn'>注意:请勿相信视频内的所有广告，否则后果自行承担。</div>\";\n    \n    if (titleText) html += \"<div class='top-title'>\" + esc(titleText) + \"</div>\";\n    \n    /* 核心播放器 */\n    html += \"<div id='playerBox'><div class='msg'>引擎初始化中...</div></div>\";\n    \n    /* 注入上下集组件 */\n    html += \"<div class='player-ctrl'>\";\n    html += \"  <button class='ctrl-btn' onclick='playPrev()'>⏮️ 上一集</button>\";\n    html += \"  <button class='ctrl-btn' onclick='playNext()'>下一集 ⏭️</button>\";\n    html += \"</div>\";\n\n    /* 历史足迹追踪器容器 */\n    html += \"<div id='historyTipWrapper' style='display:none;'><div class='history-tip' id='historyTip'></div></div>\";\n\n    /* 线路选项与正倒序组合工具栏 */\n    html += \"<div class='toolbar'>\";\n    html += \"  <div class='line-tabs' id='lineTabs'>\";\n    for (var i = 0; i < tabs.size(); i++) {\n        var name = tabs.get(i).text().trim() || (\"线路\" + (i + 1));\n        html += \"    <button class='tab-btn' onclick='switchSource(\" + i + \")'>\" + esc(name) + \"</button>\";\n    }\n    html += \"  </div>\";\n    html += \"  <button class='sort-btn' onclick='toggleSort()'>⇅ 正倒序</button>\";\n    html += \"</div>\";\n\n    /* 剧集渲染 */\n    html += \"<div id='epLists'>\";\n    for(var i = 0; i < lists.size(); i++){\n        html += \"<div class='ep-list' id='list_\" + i + \"'>\";\n        var links = lists.get(i).select(\"a\");\n        for(var j = 0; j < links.size(); j++){\n            var a = links.get(j);\n            var url = a.attr(\"href\");\n            if(url.startsWith(\"/\")) url = \"https://www.jciyuan.com\" + url;\n            var name = a.select(\"span\").text() || a.text();\n            html += \"<button class='ep-btn' id='ep_\" + i + \"_\" + j + \"' data-listidx='\" + i + \"' data-epidx='\" + j + \"' data-url='\" + url + \"' onclick='playVid(this, \\\"\" + esc(name) + \"\\\")'>\" + esc(name) + \"</button>\";\n        }\n        html += \"</div>\";\n    }\n    html += \"</div>\";\n\n    /* 前端复杂控制器 */\n    html += \"<script>\";\n    html += \"var pageTitle = decodeURIComponent('\" + encodeURIComponent(titleText) + \"');\";\n    html += \"var storageKey = 'jcy_hist_' + pageTitle;\"; // 隔离独立 key\n\n    // 切换线路\n    html += \"function switchSource(idx) {\";\n    html += \"  var tabs = document.querySelectorAll('.tab-btn');\";\n    html += \"  for (var i = 0; i < tabs.length; i++) tabs[i].classList.remove('active');\";\n    html += \"  if(tabs[idx]) tabs[idx].classList.add('active');\";\n    html += \"  var lists = document.querySelectorAll('.ep-list');\";\n    html += \"  for (var i = 0; i < lists.length; i++) lists[i].style.display = (i===idx) ? 'flex' : 'none';\";\n    html += \"}\";\n\n    // 正倒序翻转\n    html += \"function toggleSort() {\";\n    html += \"  var activeList = document.querySelector('.ep-list[style*=\\\"display: flex\\\"]') || document.querySelector('.ep-list[style*=\\\"display:flex\\\"]') || document.querySelector('.ep-list');\";\n    html += \"  if(activeList) {\";\n    html += \"    var arr = Array.prototype.slice.call(activeList.children);\";\n    html += \"    arr.reverse().forEach(function(c){ activeList.appendChild(c); });\";\n    html += \"  }\";\n    html += \"}\";\n\n    // 智能上集切换\n    html += \"function playPrev() {\";\n    html += \"  var activeBtn = document.querySelector('.ep-btn.active');\";\n    html += \"  if(!activeBtn) return;\";\n    html += \"  var listIdx = parseInt(activeBtn.getAttribute('data-listidx'));\";\n    html += \"  var epIdx = parseInt(activeBtn.getAttribute('data-epidx'));\";\n    html += \"  var prevBtn = document.getElementById('ep_' + listIdx + '_' + (epIdx - 1));\";\n    html += \"  if(prevBtn) { prevBtn.click(); } else { alert('这已经是第一集啦！'); }\";\n    html += \"}\";\n\n    // 智能下集切换\n    html += \"function playNext() {\";\n    html += \"  var activeBtn = document.querySelector('.ep-btn.active');\";\n    html += \"  if(!activeBtn) return;\";\n    html += \"  var listIdx = parseInt(activeBtn.getAttribute('data-listidx'));\";\n    html += \"  var epIdx = parseInt(activeBtn.getAttribute('data-epidx'));\";\n    html += \"  var nextBtn = document.getElementById('ep_' + listIdx + '_' + (epIdx + 1));\";\n    html += \"  if(nextBtn) { nextBtn.click(); } else { alert('已经是最后一集了，等待作者更新吧～'); }\";\n    html += \"}\";\n\n    html += \"function renderPlayer(srcObj, targetUrl) {\";\n    html += \"  var box = document.getElementById('playerBox');\";\n    html += \"  if(!srcObj) { box.innerHTML = '<div class=\\\"msg\\\">解析失败，<a href=\\\"'+targetUrl+'\\\" style=\\\"color:#4f8cff;text-decoration:none;\\\">👉 点此打开网页播放</a></div>'; return; }\";\n    html += \"  if(srcObj.isVideo) {\";\n    html += \"    box.innerHTML = '<video src=\\\"'+srcObj.url+'\\\" controls autoplay playsinline style=\\\"width:100%;height:100%;background:#000;\\\"></video>';\";\n    html += \"  } else {\";\n    html += \"    box.innerHTML = '<iframe src=\\\"'+srcObj.url+'\\\" allowfullscreen=\\\"true\\\" webkitallowfullscreen=\\\"true\\\" mozallowfullscreen=\\\"true\\\" sandbox=\\\"allow-scripts allow-same-origin allow-forms allow-presentation\\\"></iframe>';\";\n    html += \"  }\";\n    html += \"}\";\n\n    // 核心数据爬取及记录重写\n    html += \"function playVid(btn, epName) {\";\n    html += \"  var eps = document.querySelectorAll('.ep-btn'); for(var i=0; i<eps.length; i++) eps[i].classList.remove('active');\";\n    html += \"  if(btn) btn.classList.add('active');\";\n    html += \"  var targetUrl = btn.getAttribute('data-url');\";\n    html += \"  var listIdx = btn.getAttribute('data-listidx');\";\n    html += \"  var epIdx = btn.getAttribute('data-epidx');\";\n    \n    /* 同步记录至本地并刷新历史提示区 */\n    html += \"  try {\";\n    html += \"    localStorage.setItem(storageKey, JSON.stringify({listIdx: listIdx, epIdx: epIdx, name: epName}));\";\n    html += \"    document.getElementById('historyTipWrapper').style.display = 'block';\";\n    html += \"    document.getElementById('historyTip').innerHTML = '🎬 历史记录：上次查看到 <span style=\\\"color:#ff9800;font-weight:bold;\\\">' + epName + '</span>';\";\n    html += \"  } catch(e) {}\";\n\n    html += \"  var playerBox = document.getElementById('playerBox');\";\n    html += \"  playerBox.innerHTML = '<div class=\\\"msg\\\">正在验证身份并解析【' + epName + '】...</div>';\";\n    \n    html += \"  var hiddenFrame = document.getElementById('hiddenDataFetcher');\";\n    html += \"  if(!hiddenFrame) { hiddenFrame = document.createElement('iframe'); hiddenFrame.id='hiddenDataFetcher'; hiddenFrame.style.display='none'; document.body.appendChild(hiddenFrame); }\";\n    \n    html += \"  hiddenFrame.onload = function() {\";\n    html += \"    try {\";\n    html += \"      var text = hiddenFrame.contentDocument.documentElement.innerHTML;\";\n    html += \"      if(text.indexOf('您没有权限') > -1 || text.indexOf('请升级会员') > -1) {\";\n    html += \"         playerBox.innerHTML = '<div class=\\\"msg\\\" style=\\\"color:#ff4d4f;\\\">⚠️ 权限不足或需手动扣除积分<br><br><a href=\\\"'+targetUrl+'\\\" style=\\\"color:#4f8cff;text-decoration:none;\\\">👉 点此进入网页确认扣费/升级</a></div>'; return;\";\n    html += \"      }\";\n    html += \"      if(text.indexOf('Just a moment') > -1 || text.indexOf('安全拦截') > -1) {\";\n    html += \"         playerBox.innerHTML = '<div class=\\\"msg\\\" style=\\\"color:#ff9800;\\\">🛡️ 触发防爬验证<br><br><a href=\\\"'+targetUrl+'\\\" style=\\\"color:#4f8cff;text-decoration:none;\\\">👉 点此打开网页通过验证</a></div>'; return;\";\n    html += \"      }\";\n\n    html += \"      var jsReg = /(?:player_aaaa|player_data|mac_player)\\\\s*=\\\\s*(\\\\{[\\\\s\\\\S]*?\\\\})/i;\";\n    html += \"      var match = text.match(jsReg);\";\n    html += \"      if(match && match[1]) {\";\n    html += \"        try {\";\n    html += \"          var j = JSON.parse(match[1]); var v = j.url;\";\n    html += \"          if(j.encrypt==1) v=unescape(v); else if(j.encrypt==2) v=decodeURIComponent(escape(atob(v)));\";\n    html += \"          if(v.indexOf('url=')>-1) { var ex=decodeURIComponent(v.split('url=')[1].split('&')[0]); if(ex.indexOf('http')===0) v=ex; }\";\n    html += \"          if(v.startsWith('//')) v='https:'+v; else if(v.startsWith('/')) v='https://www.jciyuan.com'+v;\";\n    html += \"          renderPlayer({ url: v, isVideo: (v.indexOf('.m3u8')>-1 || v.indexOf('.mp4')>-1) }, targetUrl); return;\";\n    html += \"        } catch(e) {}\";\n    html += \"      }\";\n    html += \"      var m3u8Match = text.match(/(https?:\\\\/\\\\/[^\\\"'>\\\\s]+\\\\.m3u8[^\\\"'>\\\\s]*)/i);\";\n    html += \"      if(m3u8Match) { renderPlayer({ url: m3u8Match[1], isVideo: true }, targetUrl); return; }\";\n    html += \"      var iframeMatch = text.match(/<iframe[^>]+src=['\\\\\\\"](?!about:blank)([^'\\\\\\\"]+)['\\\\\\\"]/i);\";\n    html += \"      if(iframeMatch) {\";\n    html += \"        var u = iframeMatch[1]; if(u.startsWith('//')) u='https:'+u; else if(u.startsWith('/')) u='https://www.jciyuan.com'+u;\";\n    html += \"        renderPlayer({ url: u, isVideo: false }, targetUrl); return;\";\n    html += \"      }\";\n    html += \"      renderPlayer(null, targetUrl);\";\n    html += \"    } catch(err) {\";\n    html += \"      playerBox.innerHTML = '<div class=\\\"msg\\\">数据读取失败<br><br><a href=\\\"'+targetUrl+'\\\" style=\\\"color:#4f8cff;text-decoration:none;\\\">👉 点此打开网页播放</a></div>';\";\n    html += \"    }\";\n    html += \"  };\";\n    html += \"  hiddenFrame.src = targetUrl;\";\n    html += \"}\";\n\n    /* 初始化生命周期：智能记忆寻轨续播 */\n    html += \"setTimeout(function(){\";\n    html += \"  var histStr = localStorage.getItem(storageKey);\";\n    html += \"  var listIdx = 0, epIdx = 0;\";\n    html += \"  if(histStr) {\";\n    html += \"    try {\";\n    html += \"       var hist = JSON.parse(histStr);\";\n    html += \"       listIdx = parseInt(hist.listIdx) || 0;\";\n    html += \"       epIdx = parseInt(hist.epIdx) || 0;\";\n    html += \"       document.getElementById('historyTipWrapper').style.display = 'block';\";\n    html += \"       document.getElementById('historyTip').innerHTML = '🎬 历史记录：上次查看到 <span style=\\\"color:#ff9800;font-weight:bold;\\\">' + hist.name + '</span>';\";\n    html += \"    } catch(e) {}\";\n    html += \"  }\";\n    html += \"  switchSource(listIdx);\";\n    html += \"  var targetBtn = document.getElementById('ep_' + listIdx + '_' + epIdx);\";\n    html += \"  if(!targetBtn) targetBtn = document.getElementById('ep_0_0');\";\n    html += \"  if(targetBtn) targetBtn.click();\";\n    html += \"}, 150);\";\n\n    html += \"</script>\";\n    return html;\n})();\n</js>",
        "ruleDescription": "",
        "ruleImage": "img@data-original",
        "ruleLink": "a[href*=/acgdetail/]@href",
        "ruleNextPage": "page",
        "ruleTitle": "img@alt",
        "singleUrl": false,
        "sortUrl": "搜索::/acgsearch/{{source.getVariable()}}----------{{page}}---.html\n日本动漫::/acgshow/20--------{{page}}---.html\n欧美动漫::/acgshow/22--------{{page}}---.html\n国产动漫::/acgshow/21--------{{page}}---.html\n剧场版::/acgshow/26--------{{page}}---.html",
        "sourceGroup": "影视",
