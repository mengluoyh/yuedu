        "ruleArticles": "$.list[*]",
        "ruleContent": "<js>\nvar data = JSON.parse(result).list[0];\nvar vodId = data.vod_id;\nvar vodName = data.vod_name;\nvar playUrls = data.vod_play_url;\nvar sources = playUrls.split('$$$');\nvar targetSource = sources[0];\nfor(var j=0; j<sources.length; j++){\n    if(sources[j].indexOf('m3u8') !== -1){\n        targetSource = sources[j];\n        break;\n    }\n}\nvar episodes = targetSource.split('#');\nvar list = [];\nfor (var i=0; i<episodes.length; i++) {\n    if(!episodes[i]) continue;\n    var parts = episodes[i].split('$');\n    if(parts.length >= 2){\n        list.push({title: parts[0], url: parts[1]});\n    }\n}\nvar finalHtml = '';\nif (list.length === 0) {\n    finalHtml = '<h3 style=\"text-align:center;color:#fff;padding-top:50px;\">无播放数据</h3>';\n} else {\n    var listJson = JSON.stringify(list);\n    finalHtml += '<title>' + vodName + '</title>';\n    finalHtml += '<style>';\n    finalHtml += 'html, body { margin:0; padding:0; width:100vw; height:100vh; overflow:hidden; background:#000; font-family:sans-serif; }';\n    finalHtml += '#videoContainer { position:fixed; top:0; left:0; width:100vw; height:100vh; display:flex; flex-direction:column; background:#000; }';\n    finalHtml += '#videoPlayer { width:100%; flex:1; background:#000; object-fit:contain; }';\n    finalHtml += '#controlBar { height:50px; background:#111; display:flex; justify-content:space-between; align-items:center; padding:0 15px; border-top:1px solid #222; z-index:999; }';\n    finalHtml += '#controlBar button { padding:6px 14px; background:#222; color:#fff; border:1px solid #444; border-radius:6px; font-weight:bold; font-size:13px; }';\n    finalHtml += '#controlBar button:active { background:#444; }';\n    finalHtml += '#menuBtn { background:#ff9800 !important; border:none !important; color:#fff !important; box-shadow:0 2px 4px rgba(255,152,0,0.3); }';\n    finalHtml += '#playStatus { color:#aaa; font-size:13px; font-weight:bold; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:35%; }';\n    finalHtml += '#menuOverlay { position:fixed; bottom:-70vh; left:0; width:100vw; height:65vh; background:rgba(18,18,18,0.96); border-top:1px solid #333; border-top-left-radius:16px; border-top-right-radius:16px; z-index:9999; transition:bottom 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); display:flex; flex-direction:column; box-sizing:border-box; padding-bottom:10px; }';\n    finalHtml += '#menuOverlay.show { bottom:0; }';\n    finalHtml += '#menuHeader { display:flex; justify-content:space-between; align-items:center; padding:15px; border-bottom:1px solid #222; color:#fff; font-size:15px; }';\n    finalHtml += '#menuGrid { flex:1; overflow-y:auto; padding:10px; display:flex; flex-wrap:wrap; align-content:flex-start; }';\n    finalHtml += '.epBtn { width:calc(25% - 8px); margin:4px; padding:12px 0; background:#262626; color:#ccc; border:1px solid #3a3a3a; border-radius:8px; font-size:13px; text-align:center; font-weight:500; }';\n    finalHtml += '.epBtn.active { background:#ff9800 !important; color:#fff !important; border-color:#ff9800 !important; font-weight:bold; }';\n    finalHtml += '</style>';\n    finalHtml += '<div id=\"videoContainer\">';\n    finalHtml += '  <video id=\"videoPlayer\" controls playsinline webkit-playsinline></video>';\n    finalHtml += '  <div id=\"controlBar\">';\n    finalHtml += '    <button onclick=\"playNext(-1)\">上一集</button>';\n    finalHtml += '    <button id=\"menuBtn\" onclick=\"toggleMenu(true)\">选集</button>';\n    finalHtml += '    <span id=\"playStatus\">载入中...</span>';\n    finalHtml += '    <button onclick=\"playNext(1)\">下一集</button>';\n    finalHtml += '  </div>';\n    finalHtml += '</div>';\n    finalHtml += '<div id=\"menuOverlay\">';\n    finalHtml += '  <div id=\"menuHeader\">';\n    finalHtml += '    <span style=\"font-weight:bold;\">选集列表</span>';\n    finalHtml += '    <span onclick=\"toggleMenu(false)\" style=\"color:#ff9800; font-weight:bold; cursor:pointer; padding:5px 10px;\">关闭</span>';\n    finalHtml += '  </div>';\n    finalHtml += '  <div id=\"menuGrid\">';\n    for (var k=0; k<list.length; k++) {\n        finalHtml += '<button class=\"epBtn\" id=\"epBtn_' + k + '\" onclick=\"playEp(' + k + ')\">' + list[k].title + '</button>';\n    }\n    finalHtml += '  </div>';\n    finalHtml += '</div>';\n    finalHtml += '<script src=\"https://cdn.jsdelivr.net/npm/hls.js@1\"></script>';\n    finalHtml += '<script>';\n    finalHtml += 'var epList = ' + listJson + ';';\n    finalHtml += 'var vodId = \"' + vodId + '\";';\n    finalHtml += 'var vodName = \"' + vodName + '\";';\n    finalHtml += 'var hls = null;';\n    finalHtml += 'var video = document.getElementById(\"videoPlayer\");';\n    finalHtml += 'var currentIdx = 0; var startTime = 0;';\n    finalHtml += 'var saved = localStorage.getItem(\"ww_hist_\" + vodId);';\n    finalHtml += 'if(saved) { try{ var st = JSON.parse(saved); currentIdx = st.ep || 0; startTime = st.time || 0; }catch(e){} }';\n    finalHtml += 'function playEp(idx, seekTime) {';\n    finalHtml += '  if(idx < 0 || idx >= epList.length) { alert(\"全部播放完毕\"); return; }';\n    finalHtml += '  var oldBtn = document.getElementById(\"epBtn_\" + currentIdx); if(oldBtn) oldBtn.classList.remove(\"active\");';\n    finalHtml += '  currentIdx = idx;';\n    finalHtml += '  saveHistory();';\n    finalHtml += '  var newBtn = document.getElementById(\"epBtn_\" + currentIdx); if(newBtn) { newBtn.classList.add(\"active\"); newBtn.scrollIntoView({block:\"center\", behavior:\"smooth\"}); }';\n    finalHtml += '  var url = epList[idx].url;';\n    finalHtml += '  if(typeof Hls !== \"undefined\" && Hls.isSupported()) {';\n    finalHtml += '    if(hls) { hls.destroy(); }';\n    finalHtml += '    hls = new Hls(); hls.loadSource(url); hls.attachMedia(video);';\n    finalHtml += '    hls.on(Hls.Events.MANIFEST_PARSED, function() { if(seekTime) video.currentTime = seekTime; video.play().catch(function(e){ console.log(e); }); });';\n    finalHtml += '  } else if (video.canPlayType(\"application/vnd.apple.mpegurl\")) {';\n    finalHtml += '    video.src = url;';\n    finalHtml += '    video.addEventListener(\"loadedmetadata\", function() { if(seekTime) video.currentTime = seekTime; video.play(); }, {once:true});';\n    finalHtml += '  }';\n    finalHtml += '  document.getElementById(\"playStatus\").innerText = epList[idx].title;';\n    finalHtml += '  document.title = vodName + \" - \" + epList[idx].title;';\n    finalHtml += '  toggleMenu(false);';\n    finalHtml += '}';\n    finalHtml += 'function playNext(step) { playEp(currentIdx + step, 0); }';\n    finalHtml += 'function toggleMenu(show) {';\n    finalHtml += '  var menu = document.getElementById(\"menuOverlay\");';\n    finalHtml += '  if(show) { menu.classList.add(\"show\"); } else { menu.classList.remove(\"show\"); }';\n    finalHtml += '}';\n    finalHtml += 'function saveHistory() { localStorage.setItem(\"ww_hist_\" + vodId, JSON.stringify({ep: currentIdx, time: video.currentTime})); }';\n    finalHtml += 'video.addEventListener(\"timeupdate\", function() { if(Math.floor(video.currentTime) % 5 === 0) saveHistory(); });';\n    finalHtml += 'video.addEventListener(\"pause\", saveHistory);';\n    finalHtml += 'video.addEventListener(\"ended\", function() { playNext(1); });';\n    finalHtml += 'playEp(currentIdx, startTime);';\n    finalHtml += '</script>';\n}\nfinalHtml;\n</js>",
        "ruleDescription": "",
        "ruleImage": "$.vod_pic",
